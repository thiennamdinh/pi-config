#!/usr/bin/env bash
set -euo pipefail

REAL_PI="${PI_REAL_BIN:-/home/tdinh/.nvm/versions/node/v24.16.0/bin/pi}"
AGENTS_ROOT="${PI_AGENTS_ROOT:-$HOME/.pi/agents}"

agent=""
args=()
while (($#)); do
  case "$1" in
    --agent)
      if (($# < 2)); then
        echo "pi: --agent requires a name" >&2
        exit 2
      fi
      agent="$2"
      shift 2
      ;;
    --agent=*)
      agent="${1#--agent=}"
      shift
      ;;
    *)
      args+=("$1")
      shift
      ;;
  esac
done

if [[ -z "$agent" || "$agent" == "pi" ]]; then
  exec "$REAL_PI" "${args[@]}"
fi

if [[ ! "$agent" =~ ^[A-Za-z0-9][A-Za-z0-9._-]*[A-Za-z0-9]$|^[A-Za-z0-9]$ ]]; then
  echo "pi: invalid agent name: $agent" >&2
  exit 2
fi

agent_dir="$AGENTS_ROOT/$agent"
manifest="$agent_dir/manifest.json"
session_dir="$agent_dir/session"

if [[ ! -f "$manifest" ]]; then
  echo "pi: unknown agent: $agent" >&2
  exit 2
fi

session_file="$(python3 - "$manifest" <<'PY'
import json, sys
try:
    with open(sys.argv[1], 'r', encoding='utf-8') as f:
        value = json.load(f).get('sessionFile') or ''
    print(value)
except Exception:
    print('')
PY
)"

cd "$agent_dir"
export PI_CODING_AGENT_SESSION_DIR="$session_dir"

if [[ -n "$session_file" && -f "$session_file" ]]; then
  exec "$REAL_PI" --session "$session_file" "${args[@]}"
fi

exec "$REAL_PI" --session-dir "$session_dir" "${args[@]}"
